{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jarvis-runtime.dev/specs/worker.schema.json",
  "title": "Worker Protocol",
  "description": "所有 Worker 的统一协议。Worker 禁止输出自然语言解释，只能输出结构化 JSON。",
  "type": "object",
  "required": ["name", "version", "accepts", "returns"],
  "properties": {
    "name": {
      "type": "string",
      "description": "Worker 名称，全项目唯一",
      "pattern": "^[A-Z][a-zA-Z]+Worker$"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "accepts": {
      "type": "array",
      "items": { "type": "string" },
      "description": "该 Worker 可处理的 task type 列表"
    },
    "returns": {
      "type": "string",
      "description": "输出文件名模板"
    },
    "model": {
      "type": "string",
      "description": "调用的 AI 模型",
      "enum": ["deepseek-chat", "gpt-4o", "gpt-4o-mini", "claude-sonnet-4-20250514", "gemini-2.5-flash", "qwen-max", "local"]
    },
    "timeout_ms": {
      "type": "integer",
      "default": 120000
    },
    "retry": {
      "type": "object",
      "properties": {
        "max": { "type": "integer", "default": 3 },
        "backoff_ms": { "type": "integer", "default": 1000 }
      }
    },
    "dependencies": {
      "type": "array",
      "items": { "type": "string" },
      "description": "依赖的其他 Worker 名称列表"
    },
    "output_schema": {
      "type": "object",
      "description": "Worker 输出的 JSON Schema 引用",
      "properties": {
        "ref": { "type": "string" }
      }
    }
  }
}
