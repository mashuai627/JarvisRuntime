{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jarvis-runtime.dev/specs/worker.schema.json",
  "title": "Worker Protocol v2",
  "description": "所有 Worker 的统一协议。Worker 禁止输出自然语言，只能输出结构化 JSON。",
  "type": "object",
  "required": ["name", "version", "capabilities", "returns"],
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[A-Z][a-zA-Z]+Worker$"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "capabilities": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Worker 的能力标签。Scheduler 通过 capabilities 自动发现匹配的 Worker。",
      "examples": [
        ["script", "text_generation"],
        ["storyboard", "image_prompt"],
        ["image", "comfyui", "stable_diffusion"],
        ["video", "ffmpeg", "compositing"],
        ["audio", "tts", "voice_synthesis"],
        ["review", "quality_check"]
      ]
    },
    "returns": {
      "type": "string",
      "description": "输出文件名模板"
    },
    "model": {
      "type": "string",
      "enum": ["deepseek-chat", "gpt-4o", "gpt-4o-mini", "claude-sonnet-4-20250514", "gemini-2.5-flash", "qwen-max", "local"]
    },
    "fallback_model": {
      "type": "string",
      "description": "主模型不可用时的降级模型"
    },
    "timeout_ms": {
      "type": "integer",
      "default": 120000
    },
    "retry": {
      "type": "object",
      "properties": {
        "max": { "type": "integer", "default": 3 },
        "backoff_ms": { "type": "integer", "default": 1000 }
      }
    },
    "output_schema_ref": {
      "type": "string",
      "description": "输出 JSON Schema 文件路径引用"
    },
    "events": {
      "type": "object",
      "description": "Worker 发布/订阅的事件",
      "properties": {
        "publishes": { "type": "array", "items": { "type": "string" } },
        "subscribes": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
