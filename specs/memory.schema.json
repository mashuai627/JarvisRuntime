{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jarvis-runtime.dev/specs/memory.schema.json",
  "title": "Memory Protocol v2",
  "description": "事实记忆协议。只存事实（角色/世界/资产/剧集/地点），不存 Prompt。Prompt 永远即时生成。",
  "type": "object",
  "required": ["id", "type", "data"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^MEM-\\d{4}$"
    },
    "type": {
      "type": "string",
      "enum": [
        "character",
        "world",
        "asset_catalog",
        "episode",
        "location",
        "relationship",
        "timeline",
        "rule",
        "custom"
      ],
      "description": "记忆类型——只存事实，不存 Prompt"
    },
    "data": { "type": "object", "description": "事实数据" },
    "tags": { "type": "array", "items": { "type": "string" } },
    "project": { "type": "string" },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" }
  },
  "examples": {
    "character": {
      "id": "MEM-0001",
      "type": "character",
      "data": {
        "name": "孙悟空",
        "aliases": ["齐天大圣", "美猴王"],
        "species": "石猴",
        "abilities": ["七十二变", "筋斗云", "火眼金睛"],
        "weapon": "如意金箍棒",
        "relationships": {
          "master": "唐僧",
          "brothers": ["猪八戒", "沙僧"]
        }
      }
    },
    "world": {
      "id": "MEM-0010",
      "type": "world",
      "data": {
        "name": "西游世界",
        "realms": ["天庭", "人间", "地府", "龙宫"],
        "rules": ["神仙不可直接干预凡间", "妖怪修炼可成仙"],
        "timeline": "唐朝贞观年间"
      }
    },
    "episode": {
      "id": "MEM-0100",
      "type": "episode",
      "data": {
        "project": "西游记",
        "episode": 1,
        "title": "猴王出世",
        "summary": "花果山仙石迸裂，产一石猴...",
        "characters_introduced": ["孙悟空"],
        "locations": ["花果山", "水帘洞"]
      }
    }
  }
}
