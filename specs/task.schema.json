{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jarvis-runtime.dev/specs/task.schema.json",
  "title": "Task Protocol v2",
  "description": "系统唯一驱动单元。Task 替代 Prompt。支持 DAG 依赖和完整生命周期。",
  "type": "object",
  "required": ["id", "type", "status"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^TASK-\\d{4}$"
    },
    "type": {
      "type": "string",
      "description": "任务类型，必须匹配 Worker 的 capabilities"
    },
    "status": {
      "type": "string",
      "enum": [
        "created",
        "queued",
        "running",
        "waiting",
        "reviewing",
        "completed",
        "failed",
        "cancelled"
      ],
      "description": "生命周期: created→queued→running→waiting/reviewing→completed/failed/cancelled"
    },
    "input": {
      "type": "object",
      "description": "任务输入参数",
      "additionalProperties": true
    },
    "output": {
      "type": "object",
      "description": "status=completed 时必填",
      "properties": {
        "path": { "type": "string" },
        "format": { "type": "string" },
        "size": { "type": "integer" },
        "checksum": { "type": "string" }
      }
    },
    "error": {
      "type": "object",
      "description": "status=failed 时必填",
      "properties": {
        "code": { "type": "string" },
        "message": { "type": "string" },
        "worker": { "type": "string" }
      }
    },
    "worker": { "type": "string", "description": "执行该任务的 Worker 名称" },
    "parent": {
      "type": "string",
      "description": "父任务 ID。DAG 上游依赖。"
    },
    "dependencies": {
      "type": "array",
      "items": { "type": "string" },
      "description": "依赖的任务 ID 列表。所有依赖完成后本任务才可执行。"
    },
    "children": {
      "type": "array",
      "items": { "type": "string" },
      "description": "子任务 ID 列表。DAG 下游。"
    },
    "created_at": { "type": "string", "format": "date-time" },
    "queued_at": { "type": "string", "format": "date-time" },
    "started_at": { "type": "string", "format": "date-time" },
    "completed_at": { "type": "string", "format": "date-time" },
    "retry_count": { "type": "integer", "default": 0, "maximum": 3 },
    "priority": { "type": "integer", "default": 0, "minimum": 0, "maximum": 10 },
    "timeout_ms": { "type": "integer", "default": 600000 },
    "tags": { "type": "array", "items": { "type": "string" } },
    "project": { "type": "string", "description": "所属项目 ID" }
  }
}
