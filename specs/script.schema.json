{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jarvis-runtime.dev/specs/script.schema.json",
  "title": "Script Protocol",
  "description": "剧本输出协议。ScriptWorker 的输出必须严格遵循此 schema。",
  "type": "object",
  "required": ["project", "episode", "scenes"],
  "properties": {
    "project": { "type": "string" },
    "episode": { "type": "integer", "minimum": 1 },
    "title": { "type": "string" },
    "genre": { "type": "string" },
    "summary": { "type": "string", "description": "本集摘要（≤200字）" },
    "scenes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["scene_id", "location", "narrative"],
        "properties": {
          "scene_id": { "type": "integer", "minimum": 1 },
          "location": { "type": "string" },
          "time": { "type": "string" },
          "characters": {
            "type": "array",
            "items": { "type": "string" }
          },
          "narrative": { "type": "string", "description": "旁白/叙述文字" },
          "dialogues": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["speaker", "text"],
              "properties": {
                "speaker": { "type": "string" },
                "text": { "type": "string" },
                "emotion": { "type": "string", "description": "说话情绪" },
                "action": { "type": "string", "description": "伴随动作" }
              }
            }
          },
          "visual_hint": { "type": "string", "description": "给 ImageWorker 的画面提示" },
          "sfx": { "type": "string", "description": "音效提示" },
          "duration_sec": { "type": "integer", "default": 30 }
        }
      }
    },
    "metadata": {
      "type": "object",
      "properties": {
        "word_count": { "type": "integer" },
        "scene_count": { "type": "integer" },
        "character_count": { "type": "integer" },
        "generated_by": { "type": "string" },
        "model": { "type": "string" }
      }
    }
  }
}
