{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jarvis-runtime.dev/specs/runtime.schema.json",
  "title": "Runtime Protocol",
  "description": "Runtime 核心协议。定义 Task Queue、Scheduler、Logger 等基础设施。",
  "type": "object",
  "required": ["version"],
  "properties": {
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "task_queue": {
      "type": "object",
      "description": "任务队列配置",
      "properties": {
        "max_concurrent": { "type": "integer", "default": 4 },
        "max_queue_size": { "type": "integer", "default": 100 },
        "strategy": { "type": "string", "enum": ["fifo", "priority", "dependency"], "default": "priority" }
      }
    },
    "scheduler": {
      "type": "object",
      "properties": {
        "poll_interval_ms": { "type": "integer", "default": 500 },
        "heartbeat_timeout_ms": { "type": "integer", "default": 30000 }
      }
    },
    "logger": {
      "type": "object",
      "properties": {
        "level": { "type": "string", "enum": ["debug", "info", "warn", "error"], "default": "info" },
        "output": { "type": "string", "enum": ["stdout", "file", "both"], "default": "both" },
        "log_dir": { "type": "string", "default": "logs/" }
      }
    },
    "workers": {
      "type": "object",
      "description": "已注册的 Worker 清单",
      "patternProperties": {
        "^[A-Z][a-zA-Z]+Worker$": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "path": { "type": "string" },
            "model": { "type": "string" }
          }
        }
      }
    },
    "mcp": {
      "type": "object",
      "description": "MCP 工具端点配置",
      "properties": {
        "filesystem": { "type": "object", "properties": { "roots": { "type": "array", "items": { "type": "string" } } } },
        "shell": { "type": "object", "properties": { "enabled": { "type": "boolean" } } },
        "git": { "type": "object", "properties": { "enabled": { "type": "boolean" } } }
      }
    },
    "apis": {
      "type": "object",
      "description": "外部 API 配置引用（不存密钥，仅存端点）",
      "properties": {
        "deepseek": { "type": "string", "default": "https://api.deepseek.com/v1" },
        "openai": { "type": "string", "default": "https://api.openai.com/v1" },
        "comfyui": { "type": "string", "default": "http://127.0.0.1:8188" }
      }
    }
  }
}
