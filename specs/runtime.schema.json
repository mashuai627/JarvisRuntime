{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jarvis-runtime.dev/specs/runtime.schema.json",
  "title": "Runtime Protocol v2",
  "description": "Runtime 核心配置。Runtime 只知 Task，不知业务（不知 Comic/西游记/图片/视频）。",
  "type": "object",
  "required": ["version"],
  "properties": {
    "version": { "type": "string" },
    "event_bus": {
      "type": "object",
      "description": "事件总线配置",
      "properties": {
        "backend": { "type": "string", "enum": ["memory", "redis", "mqtt"], "default": "memory" },
        "events": {
          "type": "array",
          "items": { "type": "string" },
          "description": "系统预定义事件",
          "default": [
            "task.created",
            "task.queued",
            "task.started",
            "task.completed",
            "task.failed",
            "task.cancelled",
            "task.review_requested",
            "task.review_approved",
            "task.review_rejected",
            "worker.registered",
            "worker.unregistered",
            "system.heartbeat",
            "system.error"
          ]
        }
      }
    },
    "queue": {
      "type": "object",
      "properties": {
        "max_size": { "type": "integer", "default": 1000 },
        "persist": { "type": "boolean", "default": true },
        "storage_path": { "type": "string", "default": "runtime/queue.db" }
      }
    },
    "scheduler": {
      "type": "object",
      "properties": {
        "strategy": { "type": "string", "enum": ["priority", "fifo", "dag"], "default": "dag" },
        "max_concurrent": { "type": "integer", "default": 4 },
        "poll_interval_ms": { "type": "integer", "default": 500 }
      }
    },
    "registry": {
      "type": "object",
      "properties": {
        "auto_discover": { "type": "boolean", "default": true },
        "discover_paths": { "type": "array", "items": { "type": "string" }, "default": ["workers/"] }
      }
    },
    "adapters": {
      "type": "object",
      "description": "Tool 后端适配器配置。不绑定 MCP。",
      "properties": {
        "default": { "type": "string", "default": "local" },
        "mcp": { "type": "object", "properties": { "enabled": { "type": "boolean" } } },
        "local": { "type": "object", "properties": { "enabled": { "type": "boolean", "default": true } } },
        "docker": { "type": "object", "properties": { "enabled": { "type": "boolean" } } },
        "ssh": { "type": "object", "properties": { "enabled": { "type": "boolean" } } }
      }
    }
  }
}
